# ────────────────────────────────────────────────
# TenantCore — Environment Configuration
# Copy to .env and fill in your values
# ────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000
APP_NAME=TenantCore
APP_VERSION=1.0.0
API_BASE_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:5173

# Master Database (MongoDB)
MONGODB_MASTER_URI=mongodb://mongo:27017/tenantcore_master
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUEUE_DB=1

# JWT Secrets — use 64+ char random strings in production
JWT_ACCESS_SECRET=47aed33e7c2e8a760f39f6567235d6f2756346066bb2d7b7bd2218e15ca41096b1c3e99f288b94b6846640f6aba0b3a1d8d92f4b86ef8e5d661abf92ebe77595
JWT_REFRESH_SECRET=1b5860f3ddbf692962e3d0681ac8c71a19fd0aa6cccc3044ebd56615cf205d963a400a40c1f1b011d263601ffe0fde385a5da6a8cf5a5cba5ccfe7bf1aaef3b2
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=12

# MinIO (S3-compatible Object Storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tenant-files

# Meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_ADMIN_API_KEY=masterKey

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=vk4780024@gmail.com
SMTP_PASS="hthu vnoh ohyb ahdr"
SMTP_FROM=TenantCore <vk4780024@gmail.com>

# Loki (Logging)
LOKI_HOST=http://loki:3100

# Jaeger (Tracing)
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# Super Admin
SUPER_ADMIN_EMAIL=admin@tenantcore.com
SUPER_ADMIN_PASSWORD_HASH=$2a$10$Da7SqqMXguufLxV7oUyDtOzRpJt9vqNKiTaaUsHbUrB6yNgVQtSOO

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_REDIS_PREFIX=ratelimit

# Queue Engine
QUEUE_REDIS_DB=1
QUEUE_CONCURRENCY_EMAIL=10
QUEUE_CONCURRENCY_REPORTS=3
QUEUE_CONCURRENCY_CLEANUP=5

# Feature Flags
FEATURE_FLAG_CACHE_TTL=60

# Encryption key for sensitive data (32 bytes hex)
ENCRYPTION_KEY=b3dab91449c9c5349ca35fcd41c7ce519f5873e3c11f90597260d56d8420c094

# Webhook secret for validating outbound webhooks
WEBHOOK_SECRET=9015f48c646231861550363bc0b1aca9d4f5f93ef9dbc14743dbc24b0677d1248f49a3c799722dad270a4fa6ed7705fe0632f7da77fdb31ffc2e3ac6e0652eb8

# Domain base for subdomain routing
DOMAIN_BASE=lvh.me
