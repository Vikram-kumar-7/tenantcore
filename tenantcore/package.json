{
  "name": "tenantcore",
  "version": "1.0.0",
  "description": "TenantCore — Multi-Tenant SaaS Infrastructure Platform",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/workers",
    "apps/dashboard",
    "packages/queue-engine",
    "packages/sdk"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:workers\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:workers": "npm run dev --workspace=apps/workers",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
    "build": "npm run build --workspaces",
    "lint": "eslint apps packages --ext .js,.jsx",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "jsonwebtoken": "^9.0.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
